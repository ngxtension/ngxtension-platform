---
import Default from '@astrojs/starlight/components/PageTitle.astro';
import type { Props } from '@astrojs/starlight/props';
import { Icon } from '@astrojs/starlight/components';

const badge = Astro.locals.starlightRoute?.entry?.data?.badge;
const entryPoint = Astro.locals.starlightRoute?.entry?.data?.entryPoint;
const bundleJsUrl = entryPoint ? `https://deno.bundlejs.com?q=${entryPoint}&treeshake=[*]&config={%22esbuild%22:{%22external%22:[%22rxjs%22,%22@angular/core%22,%22@angular/common%22,%22@angular/forms%22,%22@angular/router%22]}}` : null;
const sourceCodeUrl = entryPoint ? `https://github.com/ngxtension/ngxtension-platform/tree/main/libs/${entryPoint}` : null;

let size = 'N/A';
if (bundleJsUrl) {
	try {
		const response = await fetch(bundleJsUrl);
		if (response.ok) {
			const data = await response.json();
			size = data.size?.size || 'N/A';
		}
	} catch (error) {
		console.error('Failed to fetch bundle size:', error);
	}
}
---

<div class="page-title-content">
	<Default {...Astro.props}><slot /></Default>
	<div class="chip-container">
		{badge && <div class="chip">{badge}</div>}
		{
			entryPoint && (
				<>
					<div
						class="chip"
						title="This is the compressed bundled size that includes all entry points this entry point depends on."
					>
						<a href={bundleJsUrl} target="_blank" rel="noreferrer noreferrer">
							{size}
						</a>
					</div>
					<div class="chip">
						<a href={sourceCodeUrl} target="_blank" rel="noreferrer noreferrer">
							<Icon class="icon" name="github" size="1rem" />
							Code
						</a>
					</div>
				</>
			)
		}
	</div>
</div>

<style>
	.page-title-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	@media (max-width: 1010px) {
		.page-title-content {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	.chip-container {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.chip {
		border-width: 1px;
		border-style: solid;
		border-radius: 6px;
		padding: 2px 8px;
		color: var(--sl-color-text);
		width: fit-content;
		height: fit-content;
		margin-top: 1rem;
	}

	.chip a {
		text-decoration: none;
		color: var(--sl-color-text);
	}

	.icon {
		margin-top: -3px;
		vertical-align: middle;
	}
</style>
