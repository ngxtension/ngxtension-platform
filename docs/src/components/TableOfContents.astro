---
import Default from '@astrojs/starlight/components/TableOfContents.astro';
import type { Props } from '@astrojs/starlight/props';
---

<Default {...Astro.props}><slot /></Default>

<div class="sponsor-section">
	<h2>Support ngxtension</h2>
	<p>If you find ngxtension useful, please consider sponsoring the project!</p>
	<div class="sponsor-links">
		<a
			href="https://opencollective.com/ngxtension"
			target="_blank"
			rel="noopener noreferrer"
			class="sponsor-button primary"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 16 16"
				width="16"
				height="16"
				aria-hidden="true"
			>
				<path
					fill="currentColor"
					d="m8 14.25.345.666a.75.75 0 0 1-.690 0l-.008-.004-.018-.01a7.152 7.152 0 0 1-.31-.17 22.055 22.055 0 0 1-3.434-2.414C2.045 10.731 0 8.35 0 5.5 0 2.836 2.086 1 4.25 1 5.797 1 7.153 1.802 8 3.02 8.847 1.802 10.203 1 11.75 1 13.914 1 16 2.836 16 5.5c0 2.85-2.045 5.231-3.885 6.818a22.066 22.066 0 0 1-3.744 2.584l-.018.01-.006.003h-.002ZM4.25 2.5c-1.336 0-2.75 1.164-2.75 3 0 2.15 1.58 4.144 3.365 5.682A20.58 20.58 0 0 0 8 13.393a20.58 20.58 0 0 0 3.135-2.211C12.92 9.644 14.5 7.65 14.5 5.5c0-1.836-1.414-3-2.75-3-1.373 0-2.609.986-3.029 2.456a.749.749 0 0 1-1.442 0C6.859 3.486 5.623 2.5 4.25 2.5Z"
				></path>
			</svg>
			Sponsor
		</a>
		<div class="sponsor-row">
			<a
				href="https://github.com/sponsors/eneajaho"
				target="_blank"
				rel="noopener noreferrer"
				class="sponsor-button secondary"
				title="Sponsor Enea Jahollari"
			>
				@eneajaho
			</a>
			<a
				href="https://github.com/sponsors/nartc"
				target="_blank"
				rel="noopener noreferrer"
				class="sponsor-button secondary"
				title="Sponsor Chau Tran"
			>
				@nartc
			</a>
		</div>
	</div>
</div>

<style>
	.sponsor-section {
		margin-top: 2rem;
		padding: 1rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 8px;
		background: var(--sl-color-bg-nav);
	}

	.sponsor-section h2 {
		font-size: var(--sl-text-sm);
		font-weight: 600;
		margin: 0 0 0.5rem 0;
		color: var(--sl-color-white);
	}

	.sponsor-section p {
		font-size: var(--sl-text-xs);
		margin: 0 0 1rem 0;
		color: var(--sl-color-gray-2);
		line-height: 1.5;
	}

	.sponsor-links {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.sponsor-links .secondary {
		flex: 1;
	}

	.sponsor-links .primary {
		width: 100%;
	}

	.sponsor-row {
		display: flex;
		gap: 0.5rem;
	}

	.sponsor-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		color: white;
		text-decoration: none;
		border-radius: 6px;
		font-size: var(--sl-text-xs);
		font-weight: 500;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.sponsor-button.primary {
		background: linear-gradient(135deg, #ea4aaa 0%, #ea4c89 100%);
	}

	.sponsor-button.primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(234, 76, 137, 0.3);
	}

	.sponsor-button.secondary {
		background: var(--sl-color-gray-5);
		color: var(--sl-color-gray-1);
	}

	.sponsor-button.secondary:hover {
		background: var(--sl-color-gray-4);
		transform: translateY(-1px);
	}

	.sponsor-button svg {
		width: 16px;
		height: 16px;
	}
</style>
